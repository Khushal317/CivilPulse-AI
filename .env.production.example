# CivicPulse AI production environment template.
# Copy values into your deployment platform secret manager, not into git.

# Application
APP_ENV=production
APP_NAME=CivicPulse AI API
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO

# HTTPS-only browser origins allowed to call FastAPI.
# Example: https://civicpulse.example.com
CORS_ORIGINS=https://replace-with-production-frontend.example.com

# PostgreSQL
# Use managed PostgreSQL in production. For Cloud SQL via Cloud Run, this can be
# either a private IP hostname URL or a Cloud SQL connector/proxy-compatible URL.
DATABASE_URL=postgresql+psycopg://civicpulse:replace-with-secret@replace-with-host:5432/civicpulse
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_ECHO=false

# Frontend build variables
# These are build-time values for the frontend image/static host.
VITE_API_BASE_URL=https://replace-with-production-api.example.com
VITE_GOOGLE_MAPS_API_KEY=replace-with-browser-restricted-google-maps-key

# Gemini and analysis
AI_PROVIDER=gemini
GEMINI_API_KEY=replace-with-backend-only-gemini-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=10
GEMINI_MAX_ATTEMPTS=1
AI_PROMPT_VERSION=civic-report-v1

# Reporting and anonymous community action limits
REPORT_ANALYSIS_RATE_LIMIT=10
REPORT_ANALYSIS_RATE_WINDOW_MINUTES=60
REPORT_DRAFT_TTL_MINUTES=60
ANONYMOUS_ACTOR_SECRET=replace-with-long-random-production-secret
COMMUNITY_ACTION_RATE_LIMIT=20
COMMUNITY_ACTION_RATE_WINDOW_MINUTES=60
MAX_IMAGE_SIZE_BYTES=10485760
MAX_IMAGE_PIXELS=40000000

# Admin authentication
ADMIN_USERNAME=admin
# Generate with: cd backend && .venv/bin/python -m scripts.hash_admin_password
ADMIN_PASSWORD_HASH=replace-with-single-quoted-scrypt-hash-in-secret-manager
ADMIN_SESSION_SECRET=replace-with-long-random-production-secret
ADMIN_SESSION_TTL_MINUTES=480
ADMIN_LOGIN_RATE_LIMIT=5
ADMIN_LOGIN_RATE_WINDOW_MINUTES=15

# Object storage
STORAGE_BACKEND=gcs
LOCAL_STORAGE_PATH=storage
STORAGE_BUCKET=replace-with-production-gcs-bucket
