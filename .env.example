# Application
APP_ENV=development
APP_NAME=CivicPulse AI API
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# Browser origins allowed to call FastAPI (comma-separated)
CORS_ORIGINS=http://localhost:5173

# PostgreSQL
POSTGRES_DB=civicpulse
POSTGRES_USER=civicpulse
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://civicpulse:change-me@postgres:5432/civicpulse

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Gemini (used in Phase 4)
GEMINI_API_KEY=
GEMINI_MODEL=

# Admin authentication (used in Phase 7)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# Object storage (used in Phase 4)
STORAGE_BACKEND=local
STORAGE_BUCKET=

