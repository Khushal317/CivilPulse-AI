# Application
APP_ENV=development
APP_NAME=CivicPulse AI API
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# Browser origins allowed to call FastAPI (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
POSTGRES_DB=civicpulse
POSTGRES_USER=civicpulse
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://civicpulse:change-me@postgres:5432/civicpulse
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_ECHO=false

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Gemini and analysis
AI_PROVIDER=demo
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=45
GEMINI_MAX_ATTEMPTS=2
AI_PROMPT_VERSION=civic-report-v1
REPORT_DRAFT_TTL_MINUTES=60
MAX_IMAGE_SIZE_BYTES=10485760
MAX_IMAGE_PIXELS=40000000

# Admin authentication (used in Phase 7)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# Object storage (used in Phase 4)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=storage
STORAGE_BUCKET=
